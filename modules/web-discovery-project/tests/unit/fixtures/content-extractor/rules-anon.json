{
  "search-google": {
    "input": {
      "div#rso div.g": {
        "all": {
          "t": {
            "select": "a > br + h3, g-section-with-header g-link > a > h3",
            "attr": "textContent"
          },
          "u": {
            "select": "div.yuRUbf > div > span[role=link] > a[jsname], div.yuRUbf > div > span > a, div.yuRUbf > div > a[jsname], div.nhaZ2c > div > span > a, div.DhN8Cf > div > a[jsname], g-section-with-header g-link > a.a-no-hover-decoration",
            "attr": "href",
            "transform": [["trySplit", "?ref_src=twsrc", 0]]
          },
          "age": {
            "select": "div > span.MUxGbd > span, div.mSA5Bd > div.P7xzyf > span > span",
            "attr": "textContent"
          },
          "m": {
            "select": ".TXwUJf a.fl",
            "attr": "textContent"
          }
        }
      },
      "#search": {
        "first": {
          "q": {
            "select": "#rso",
            "attr": "data-async-context",
            "transform": [
              ["trySplit", "query:", 1],
              ["decodeURIComponent"]
            ]
          }
        }
      },
      "div#rcnt.GyAeWb div#rso > div.ULSxyf, div#rcnt.GyAeWb > div.M8OgIe": {
        "all": {
          "u": {
            "select": "div.yuRUbf a",
            "attr": "href",
            "transform": [
              ["trySplit", "#", 0],
              ["maskU"]
            ]
          }
        }
      },
      "#search g-scrolling-carousel img[id^='dimg_']": {
        "all": {
          "u": {
            "attr": "title"
          }
        }
      },
      "div.EyBRub div[data-lpage]": {
        "all": {
          "u": {
            "attr": "data-lpage"
          }
        }
      },
      "#rhs[role='complementary']": {
        "first": {
          "t": {
            "select": "[data-attrid='title'], div[role=heading]",
            "attr": "textContent"
          },
          "desc": {
            "select": "div[data-attrid='description'] div div.kno-rdesc > h3 + span:nth-last-child(2)",
            "attr": "textContent"
          },
          "u": {
            "select": "[data-attrid='description'] div.kno-rdesc > span:nth-last-child(1) > span + a",
            "attr": "href"
          }
        }
      },
      "#rhs[role='complementary'] div.wDYxhc[data-attrid^='kc:/'], #rhs[role='complementary'] div.wDYxhc[data-attrid^='ss:/']": {
        "all": {
          "prop": {
            "select": "div.rVusze > span.w8qArf:nth-child(1)",
            "attr": "textContent",
            "transform": [["trySplit", ": ", 0]]
          },
          "val": {
            "select": "div.rVusze > span:nth-child(2)",
            "attr": "textContent"
          }
        }
      }
    },
    "output": {
      "query": {
        "fields": [
          {
            "key": "r",
            "source": "div#rso div.g",
            "requiredKeys": [
              "t",
              "u"
            ]
          },
          {
            "key": "q",
            "source": "#search"
          },
          {
            "key": "qurl"
          },
